# mini-openclaw 环境配置

# ========== LLM 配置 ==========
LLM_BASE_URL=http://xx.xx.xx.xx:80/v1
LLM_API_KEY=你的APIKey
LLM_MODEL=claude-opus-4-6

# ========== 服务端口 ==========
WS_PORT=18789
HTTP_PORT=18790

# ========== 企业微信配置 ==========
# 企业ID（在"我的企业"页面获取）
WECOM_CORP_ID=YOUR_CORP_ID

# 应用Secret（在应用详情页获取）
WECOM_SECRET=YOUR_SECRET

# 应用AgentId（在应用详情页获取）
WECOM_AGENT_ID=YOUR_AGENT_ID

# 回调验证Token（自行设置，用于回调验证）
WECOM_TOKEN=YOUR_VERIFY_TOKEN

# 回调EncodingAESKey（自行设置，43位字符）
WECOM_ENCODING_AES_KEY=YOUR_AES_KEY
