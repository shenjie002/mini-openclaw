# mini-openclaw 环境配置
# 请复制 .env.example 为 .env 并填入真实配置

# ========== LLM 配置 ==========
LLM_BASE_URL=http://192.168.111.90:8016/v1
LLM_API_KEY=sk-W1dDjsKugNYSyiO1N7j046J1hCOT0xHl4eBYTVqhiR7sFGBw
LLM_MODEL=claude-opus-4-6

# ========== 服务端口 ==========
WS_PORT=18789
HTTP_PORT=18790

# ========== 企业微信配置 ==========
WECOM_CORP_ID=YOUR_CORP_ID
WECOM_SECRET=YOUR_SECRET
WECOM_AGENT_ID=YOUR_AGENT_ID
WECOM_TOKEN=YOUR_VERIFY_TOKEN
WECOM_ENCODING_AES_KEY=YOUR_AES_KEY

# ========== Telegram Bot 配置 ==========
# 在 @BotFather 创建机器人获取 Token
TEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
# 可选：Webhook 验证 Secret
TEGRAM_SECRET=YOUR_TEGRAM_SECRET

# ========== Discord Bot 配置 ==========
# 在 Discord Developer Portal 创建应用和机器人
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
DISCORD_PUBLIC_KEY=YOUR_DISCORD_PUBLIC_KEY
DISCORD_APPLICATION_ID=YOUR_DISCORD_APPLICATION_ID
# 可选：指定服务器
DISCORD_GUILD_ID=YOUR_DISCORD_GUILD_ID

# ========== 飞书配置（可选） ==========
# 方式一：应用模式（需要企业自建应用）
FEISHU_APP_ID=YOUR_FEISHU_APP_ID
FEISHU_APP_SECRET=YOUR_FEISHU_APP_SECRET
# 方式二：Webhook 模式（群里添加自定义机器人）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/hook/xxx

# ========== 钉钉配置（可选） ==========
# 群里添加自定义机器人获取 Webhook URL
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
# 可选：加签密钥（以SEC开头的字符串）
DINGTALK_SECRET=YOUR_DINGTALK_SECRET
